---
export interface Props {
  title: string;
  description?: string;
  current: 'home' | 'knowledge' | 'relays' | 'tools';
  depth: string;
}

const { title, description, current, depth } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#0f8a5f" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${depth}favicon.png`} />
    <link rel="apple-touch-icon" href={`${depth}favicon.png`} />
    <link rel="stylesheet" href={`${depth}assets/site.css`} />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href={depth} aria-label="返回首页">
          <span class="brand-mark" aria-hidden="true">
            <svg width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 12h10" />
              <path d="m11 5 7 7-7 7" />
            </svg>
          </span>
          <span class="brand-text">
            <strong>AI 实用知识库</strong>
            <span>知识入口，工具承接</span>
          </span>
        </a>

        <nav class="nav-actions" aria-label="站点导航">
          <a class="nav-link" href={depth} aria-current={current === 'home' ? 'page' : undefined}>首页</a>
          <a class="nav-link" href={`${depth}knowledge/`} aria-current={current === 'knowledge' ? 'page' : undefined}>知识库</a>
          <a class="nav-link" href={`${depth}relays/`} aria-current={current === 'relays' ? 'page' : undefined}>API / 中转</a>
          <a class="nav-link" href={`${depth}tools/`} aria-current={current === 'tools' ? 'page' : undefined}>我的工具箱</a>
        </nav>
      </header>

      <slot />

      <footer class="footer">AI 实用知识库 · 工具分享与个人实践记录</footer>
    </main>
  </body>
</html>
