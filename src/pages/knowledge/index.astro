---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getLastUpdated } from '../../utils/lastUpdated';

const posts: CollectionEntry<'posts'>[] = await getCollection('posts');
const sorted = posts.sort((a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.date.localeCompare(a.data.date));
const lastUpdated = getLastUpdated();
---

<Base
  title="知识库 | AI 工具与中转站实用教程"
  description="AI 工具、中转站、VPS 和个人效率工具的知识文章索引。"
  current="knowledge"
  depth="../"
>
  <section class="hero">
    <span class="eyebrow">
      <span class="dot" aria-hidden="true"></span>
      Knowledge first
    </span>
    <h1>所有推荐，都先从一篇能解决问题的文章开始。</h1>
    <p class="lead">
      这里会持续整理 AI 使用、API 中转、VPS 部署和常用工具的实战经验。文章底部统一放「本文实践工具箱」，把推荐入口放在读者已经理解场景之后。
    </p>
  </section>

  <section class="section" aria-labelledby="articles-title">
    <div class="section-head">
      <div>
        <h2 id="articles-title">文章列表</h2>
        <p>按你遇到的问题分类：充值、渠道选择、工具评测和部署实战。</p>
      </div>
      <span class="badge badge-primary">持续更新</span>
    </div>

    <div class="grid-2">
      {
        sorted.map(post => (
          <a class="card card-strong link-card" href={`../knowledge/${post.slug}/`}>
            <span class="badge badge-primary">{post.data.tags[0] || '知识分享'}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.summary}</p>
            <div class="tags">
              {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))
      }

      <article class="card card-muted">
        <span class="badge">计划中</span>
        <h3>轻量 VPS 怎么选：地区、带宽和月费怎么平衡</h3>
        <p>后续会补一篇面向个人项目、AI 工具部署和轻量服务挂机的 VPS 选择指南。</p>
        <div class="tags">
          <span class="tag">VPS</span>
          <span class="tag">部署</span>
          <span class="tag">预算控制</span>
        </div>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="categories-title">
    <div class="section-head">
      <div>
        <h2 id="categories-title">内容分类</h2>
        <p>按你遇到的问题分类：充值、渠道选择、工具评测和部署实战。</p>
      </div>
    </div>
    <div class="grid-3">
      <article class="card">
        <h3>AI 使用教程</h3>
        <p>模型选择、充值方式、常见任务、提示词工作流和新手避坑。</p>
      </article>
      <article class="card">
        <h3>API / 中转</h3>
        <p>适合国内用户的 API 使用路径、稳定性判断、预算和安全注意事项。</p>
      </article>
      <article class="card">
        <h3>VPS / 部署</h3>
        <p>轻量服务器选择、部署流程、测速方法和适合个人项目的服务清单。</p>
      </article>
    </div>
  </section>

  <div class="note">
    <span><strong>说明：</strong>知识文章负责解释问题，工具箱负责承接服务入口。</span>
    <span>更新于 {lastUpdated}</span>
  </div>
</Base>
